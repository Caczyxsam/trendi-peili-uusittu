# Copy this file to `.env` and fill in a real value. `.env` is gitignored — never commit real keys.

# Anthropic API key — used server-side by the trend agents (server/trends.js).
# Get one at https://console.anthropic.com → Settings → API Keys.
ANTHROPIC_API_KEY="sk-ant-..."

# Port the Express server listens on (optional; defaults to 3001).
# PORT=3001
